APP_NAME=Precifique
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=America/Sao_Paulo
APP_URL=http://localhost

APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=pt_BR
APP_FAKER_LOCALE=pt_BR

APP_MAINTENANCE_DRIVER=file

PHP_CLI_SERVER_WORKERS=4
BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=debug

# ── Dev local rápido (sem Docker/Redis) ──
# Descomente o bloco abaixo e comente o MySQL/Redis:
# DB_CONNECTION=sqlite
# SESSION_DRIVER=file
# CACHE_STORE=file
# QUEUE_CONNECTION=sync
# Depois: New-Item database\database.sqlite -Force  →  php artisan migrate --seed

# ── Banco (MySQL 8.4 recomendado) ──
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=precifique
DB_USERNAME=precifique
DB_PASSWORD=secret

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

CACHE_STORE=file
CACHE_PREFIX=precifique_

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="contato@precifique.com.br"
MAIL_FROM_NAME="${APP_NAME}"

# S3 em produção (fotos, relatórios)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=sa-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false
# FILESYSTEM_DISK=s3

VITE_APP_NAME="${APP_NAME}"

# IA (Premium) — escolha: gemini | groq | anthropic
AI_PROVIDER=gemini
AI_VERIFY_SSL=
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Pagamentos
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=
MP_PUBLIC_KEY=
MP_ACCESS_TOKEN=
MP_WEBHOOK_SECRET=
PIX_SUBSCRIPTION_DAYS=30

# LGPD / trial
LGPD_POLICY_VERSION=1.0
TENANT_TRIAL_DAYS=14
REPORT_RETENTION_DAYS=90

# Produção — proxy reverso (nginx, Cloudflare). Vazio = não confia em proxies.
TRUSTED_PROXIES=

# Superadmin (obrigatório ADMIN_PASSWORD em produção — veja .env.production.example)
ADMIN_EMAIL=admin@precifique.com.br
ADMIN_PASSWORD=

# HTTPS forçado em produção (AppServiceProvider)
FORCE_HTTPS=

# Health check detalhado (/health) — obrigatório fora de local/testing (Bearer token)
HEALTH_CHECK_TOKEN=

# Segurança
# TENANT_DEMO_ENABLED=false
# SECURITY_PUBLIC_API_DOCS=false
# SECURITY_PRIVATE_UPLOADS=true
# TURNSTILE_SITE_KEY=
# TURNSTILE_SECRET_KEY=
# API_DOCS_TOKEN=
# SECURITY_CONTACT_EMAIL=security@precifique.com.br

# ── Produção: copie .env.production.example → .env ──
# docker compose -f docker-compose.prod.yml up -d --build
# scripts/deploy-prod.sh  |  scripts/deploy-prod.ps1

# IA — limites e exportações
AI_PREMIUM_DAILY_LIMIT=50
SALES_EXPORT_ASYNC_THRESHOLD=200
PRODUCT_IMAGE_MAX_KB=4096
PRODUCT_IMAGE_MAX_WIDTH=4000
PRODUCT_IMAGE_MAX_HEIGHT=4000
PRODUCT_IMAGE_DISPLAY_MAX_WIDTH=1200
PRODUCT_IMAGE_JPEG_QUALITY=85
TRIAL_NOTIFY_DAYS_BEFORE=3
PIX_NOTIFY_DAYS_BEFORE=3

# Analytics (opcional: plausible ou gtag)
# ANALYTICS_PROVIDER=plausible
# ANALYTICS_ID=
# ANALYTICS_DOMAIN=precifique.tdesksolutions.com.br

# Observabilidade (opcional)
# SENTRY_LARAVEL_DSN=
# SENTRY_TRACES_SAMPLE_RATE=0.1
