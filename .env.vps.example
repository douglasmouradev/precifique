# Precifique — VPS / aaPanel (sem Docker)
# Uso: cp .env.vps.example .env  →  preencha valores  →  php artisan key:generate

APP_NAME=Precifique
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=America/Sao_Paulo
APP_URL=https://seudominio.com.br

APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=pt_BR
APP_FAKER_LOCALE=pt_BR

APP_MAINTENANCE_DRIVER=file
BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=warning

FORCE_HTTPS=true

# Banco — use 127.0.0.1 (NÃO "mysql"; isso é só no Docker)
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=precifique
DB_USERNAME=precifique
DB_PASSWORD=

# Redis — instale no servidor ou use file/database (veja comentários abaixo)
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_SECURE_COOKIE=true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax
SESSION_PATH=/
SESSION_DOMAIN=

CACHE_STORE=redis
CACHE_PREFIX=precifique_
QUEUE_CONNECTION=redis

# Sem Redis ainda? Descomente estas linhas e comente redis acima:
# SESSION_DRIVER=file
# CACHE_STORE=file
# QUEUE_CONNECTION=database

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="contato@seudominio.com.br"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"

# Obrigatório em produção (preflight + ensure-admin)
ADMIN_EMAIL=admin@seudominio.com.br
ADMIN_PASSWORD=

# Gere com: openssl rand -hex 32
HEALTH_CHECK_TOKEN=

# Segurança
TENANT_DEMO_ENABLED=false
SECURITY_PUBLIC_API_DOCS=false
SECURITY_SIGNED_PRODUCT_PHOTOS=true

AI_PROVIDER=gemini
AI_VERIFY_SSL=true
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=
MP_PUBLIC_KEY=
MP_ACCESS_TOKEN=
MP_WEBHOOK_SECRET=
PIX_SUBSCRIPTION_DAYS=30

LGPD_POLICY_VERSION=1.0
TENANT_TRIAL_DAYS=14
REPORT_RETENTION_DAYS=90

TRUSTED_PROXIES=*

AI_PREMIUM_DAILY_LIMIT=50
SALES_EXPORT_ASYNC_THRESHOLD=200
PRODUCT_IMAGE_MAX_KB=4096
PRODUCT_IMAGE_MAX_WIDTH=4000
PRODUCT_IMAGE_MAX_HEIGHT=4000
TRIAL_NOTIFY_DAYS_BEFORE=3

SENTRY_LARAVEL_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
