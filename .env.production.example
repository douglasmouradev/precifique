# Precifique — Docker (docker-compose.prod.yml)
# VPS/aaPanel: use .env.vps.example em vez deste arquivo.
# Uso: cp .env.production.example .env  →  preencha valores  →  php artisan key:generate

APP_NAME=Precifique
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=America/Sao_Paulo
APP_URL=https://seudominio.com.br

APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=pt_BR
APP_FAKER_LOCALE=pt_BR

APP_MAINTENANCE_DRIVER=file
BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=warning

# Força URLs HTTPS (com TRUSTED_PROXIES atrás de Cloudflare/nginx)
FORCE_HTTPS=true

# Banco (serviço mysql no docker-compose.prod.yml)
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=precifique
DB_USERNAME=precifique
DB_PASSWORD=

# Redis (sessão, cache e filas)
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_SECURE_COOKIE=true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax
SESSION_PATH=/
SESSION_DOMAIN=

CACHE_STORE=redis
CACHE_PREFIX=precifique_
QUEUE_CONNECTION=redis

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=s3

# E-mail transacional (trial, relatórios, reset de senha)
MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="contato@seudominio.com.br"
MAIL_FROM_NAME="${APP_NAME}"

# S3 — fotos de produtos e exportações CSV
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=sa-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Superadmin inicial (obrigatório no primeiro migrate --seed ou ensure-admin)
ADMIN_EMAIL=admin@seudominio.com.br
ADMIN_PASSWORD=

# IA (Premium)
AI_PROVIDER=gemini
AI_VERIFY_SSL=true
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Pagamentos (chaves LIVE)
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=
MP_PUBLIC_KEY=
MP_ACCESS_TOKEN=
MP_WEBHOOK_SECRET=
PIX_SUBSCRIPTION_DAYS=30

# LGPD / trial
LGPD_POLICY_VERSION=1.0
TENANT_TRIAL_DAYS=14
REPORT_RETENTION_DAYS=90

# Proxy reverso: Cloudflare = *  |  nginx local = IP do proxy
TRUSTED_PROXIES=*

# Limites
AI_PREMIUM_DAILY_LIMIT=50
SALES_EXPORT_ASYNC_THRESHOLD=200
PRODUCT_IMAGE_MAX_KB=4096
PRODUCT_IMAGE_MAX_WIDTH=4000
PRODUCT_IMAGE_MAX_HEIGHT=4000
TRIAL_NOTIFY_DAYS_BEFORE=3

# Health check detalhado (/health) — obrigatório (openssl rand -hex 32)
HEALTH_CHECK_TOKEN=

# Segurança (recomendado em produção)
TENANT_DEMO_ENABLED=false
SECURITY_PUBLIC_API_DOCS=false
SECURITY_SIGNED_PRODUCT_PHOTOS=true

# Observabilidade (opcional: composer require sentry/sentry-laravel)
SENTRY_LARAVEL_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# Porta HTTP exposta pelo nginx (docker-compose.prod.yml)
APP_PORT=80
